# Music folder paths (absolute paths to your local MP3/FLAC collections)
ILAYARAJA_MUSIC_PATH=/path/to/ilayaraja/songs
ARRAHMAN_MUSIC_PATH=/path/to/arrahman/songs

# Last.fm API key (get one at https://www.last.fm/api/account/create)
LASTFM_API_KEY=your_key_here

# Server port
PORT=3003

# Auth (change in production)
JWT_SECRET=your-jwt-secret-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
